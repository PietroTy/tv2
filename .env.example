# ══════════════════════════════════════
# TV2 — Configuração
# ══════════════════════════════════════

# Porta do servidor (padrão: 3000)
PORT=3000

# Google OAuth2 (opcional — o app funciona sem)
# Crie em: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Segredo da sessão (troque por algo aleatório)
SESSION_SECRET=tv2-secret-change-me
